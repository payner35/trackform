# Phase 4a — real hostname via sslip.io wildcard DNS, real Let's Encrypt cert.
# `143-198-223-46.sslip.io` resolves to 143.198.223.46. ACME HTTP-01
# challenge requires port 80 reachable from Let's Encrypt servers.
# Swap to a vanity domain in Phase 4b.

143-198-223-46.sslip.io {

    # /v1/worker/* is internal-only — worker container reaches the service
    # via the compose network on :7777, never through Caddy. Externally
    # these paths 404 so a leaked user token still can't drive the worker
    # contract (defense in depth before HMAC lands in Phase 4b).
    @worker path /v1/worker/*
    respond @worker 404

    reverse_proxy service:7777
}
# Caddy auto-redirects HTTP→HTTPS for hostnames and handles ACME HTTP-01
# challenges on :80, so no explicit :80 block needed.
